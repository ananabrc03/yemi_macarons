# ==========================================================================
# Yémi Macarons — Variables d'environnement (exemple)
# Copier ce fichier en `.env` et remplir les valeurs.
# NE JAMAIS COMMITER LE FICHIER .env (il est exclu via .gitignore).
# Sur Hostinger : renseigner ces variables dans le panneau de l'application.
# ==========================================================================

# --- Serveur ---
# Port local (Hostinger fournit automatiquement le sien via PORT).
PORT=3000

# --- SMTP (envoi des emails de commande via Nodemailer) ---
# Exemple avec une boîte Yahoo : smtp.mail.yahoo.com, port 465, SSL,
# avec un « mot de passe d'application » généré dans le compte Yahoo.
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=adresse@exemple.com
SMTP_PASS=mot-de-passe-application

# Adresse affichée comme expéditeur (par défaut : SMTP_USER).
SMTP_FROM=adresse@exemple.com

# Boîte qui reçoit les commandes.
ORDER_EMAIL=yemi_macarons@yahoo.com
